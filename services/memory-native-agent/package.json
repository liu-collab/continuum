{
  "name": "@axis/memory-native-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Axis memory native agent service.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "mna-server": "./bin/mna-server.mjs",
    "mna": "./bin/mna-server.mjs"
  },
  "files": [
    "bin/",
    "dist/",
    "README.md",
    "RELEASE.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node ./scripts/copy-assets.mjs",
    "check": "tsc --noEmit -p tsconfig.json",
    "dev": "tsx watch bin/mna-server.mjs",
    "memory:tiering": "tsx src/devtools/memory-tiering-cli.ts",
    "start": "node bin/mna-server.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/websocket": "^11.0.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.10.0",
    "fastify": "^5.2.1",
    "pino": "^9.6.0",
    "yaml": "^2.8.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}
