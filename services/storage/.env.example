# HTTP 服务监听端口
PORT=3001
# HTTP 服务监听地址
HOST=0.0.0.0
# Pino 日志级别
LOG_LEVEL=info
# PostgreSQL 连接串，storage 只依赖自己的数据库
DATABASE_URL=postgres://postgres:postgres@localhost:5432/agent_memory
# storage 私有写模型 schema
STORAGE_SCHEMA_PRIVATE=storage_private
# storage 对外发布的共享只读模型 schema
STORAGE_SCHEMA_SHARED=storage_shared_v1
# 异步写任务轮询间隔，单位毫秒
WRITE_JOB_POLL_INTERVAL_MS=1000
# 单次 worker 抢占的写任务批大小
WRITE_JOB_BATCH_SIZE=10
# 写任务最大重试次数
WRITE_JOB_MAX_RETRIES=3
# 读模型刷新最大重试次数
READ_MODEL_REFRESH_MAX_RETRIES=3
# embedding 服务地址；未配置时读模型仍可发布，但向量字段为空
EMBEDDING_BASE_URL=
# embedding 服务鉴权 key，可为空
EMBEDDING_API_KEY=
# embedding 模型名
EMBEDDING_MODEL=text-embedding-3-small
# 健康检查里可选依赖 Redis 的地址；未配置或不可用不会阻塞 storage 启动
REDIS_URL=
