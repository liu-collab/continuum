{
  "name": "@continuum/retrieval-runtime",
  "version": "0.1.0",
  "private": true,
  "description": "Continuum retrieval runtime service and host adapters.",
  "type": "module",
  "bin": {
    "continuum-runtime": "./bin/continuum-runtime.mjs",
    "continuum-mcp-server": "./bin/continuum-mcp-server.mjs"
  },
  "files": [
    "bin/",
    "dist/src/",
    "host-adapters/",
    "migrations/",
    ".env.example",
    "README.md",
    "RELEASE.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "migrate": "tsx src/db/migrate.ts",
    "start": "node dist/src/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "fastify": "^5.2.1",
    "pg": "^8.13.3",
    "pino": "^9.6.0",
    "ws": "^8.18.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.11",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}
