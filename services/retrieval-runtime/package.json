{
  "name": "@axis/retrieval-runtime",
  "version": "0.1.0",
  "private": true,
  "description": "Axis retrieval runtime service and host adapters.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "axis-runtime": "./bin/axis-runtime.mjs",
    "axis-mcp-server": "./bin/axis-mcp-server.mjs"
  },
  "files": [
    "bin/",
    "dist/src/",
    "host-adapters/",
    "migrations/",
    "scripts/",
    ".env.example",
    "README.md",
    "RELEASE.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "migrate": "tsx src/db/migrate.ts",
    "start": "node dist/src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:importer": "vitest run tests/csv-import-validator.test.ts",
    "test:e2e": "vitest run -c vitest.e2e.config.ts",
    "test:memory-orchestrator-eval": "vitest run -c vitest.memory-orchestrator-real-eval.config.ts",
    "test:real-user-experience": "vitest run -c vitest.real-user-experience.config.ts",
    "eval:memory-orchestrator-real": "tsx src/cli/memory-orchestrator-real-eval.ts",
    "eval:real-user-experience": "node tests/e2e/real-user-experience/run-ab-eval.mjs",
    "eval:real-user-experience:host": "node tests/e2e/real-user-experience/run-real-host-ab-eval.mjs"
  },
  "dependencies": {
    "fastify": "^5.2.1",
    "pg": "^8.13.3",
    "pino": "^9.6.0",
    "ws": "^8.18.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.11",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}
