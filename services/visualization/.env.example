NEXT_PUBLIC_APP_NAME=Agent Memory Observatory
NEXT_PUBLIC_APP_DESCRIPTION=Structured memory catalog, run trace, and metrics dashboard

# storage shared read model
STORAGE_READ_MODEL_DSN=postgres://postgres:postgres@localhost:5432/agent_memory
STORAGE_READ_MODEL_SCHEMA=storage_shared_v1
STORAGE_READ_MODEL_TABLE=memory_read_model_v1
STORAGE_READ_MODEL_TIMEOUT_MS=2000

# upstream observe APIs
STORAGE_API_BASE_URL=http://localhost:3001
STORAGE_API_TIMEOUT_MS=2000
RUNTIME_API_BASE_URL=http://localhost:3002
RUNTIME_API_TIMEOUT_MS=2000

# visualization service behavior
DEFAULT_PAGE_SIZE=20
HEALTH_POLL_INTERVAL_MS=5000
SOURCE_HEALTH_CACHE_MS=8000
DASHBOARD_REFRESH_MS=30000
DASHBOARD_CACHE_MS=20000
